# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Env files with secrets (keep .env.example committed)
.env
.env.vercel
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.vercel

# Local security scan output (do not commit)
gitleaks-report.json

# Android — Firebase, signing, and machine-local config (see also android/.gitignore)
android/**/google-services.json
android/**/*.jks
android/**/*.keystore
android/app/release/
android/**/keystore.properties
android/**/signing.properties
android/key.properties

# Local scratch / duplicate tree (do not upload to Vercel)
.tmp-vercel-worktree

scripts/test-output.pdf
scripts/*.pdf
