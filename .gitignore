# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Env files with secrets (keep .env.example committed)
.env
.env.vercel
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
desktop.ini
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.vercel

# Local security scan output (do not commit)
gitleaks-report.json

# Android — Firebase, signing, and machine-local config (see also android/.gitignore)
android/**/google-services.json
android/**/*.jks
android/**/*.keystore
android/app/release/
android/**/keystore.properties
android/**/signing.properties
android/key.properties

# Local scratch / duplicate tree (do not upload to Vercel)
.tmp-vercel-worktree

scripts/test-output.pdf
scripts/*.pdf
scripts/test-official-form-spike/
scripts/test-official-form-docuseal-spike.mjs

# One-off design-system snapshot for Claude Design (not live source)
claude-design-bundle/*
!claude-design-bundle/README.md

# Supabase CLI local linked-project metadata (machine-local)
supabase/.temp/

# Tokyo migration reference dumps (local only; Sydney is production)
supabase/tokyo_*.sql
