  },
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "quni-living.vercel.app"
        }
      ],
      "destination": "https://quni.com.au/",
      "statusCode": 308
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "quni-living.vercel.app"
        }
      ],
      "destination": "https://quni.com.au/:path*",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).+)",
      "destination": "/index.html"
    },
    { "source": "/", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/expire-bookings", "schedule": "0 * * * *" },
    { "path": "/api/cron/release-deposits", "schedule": "0 0 * * *" },
    { "path": "/api/cron/docuseal-health", "schedule": "30 * * * *" },
    { "path": "/api/cron/github-health", "schedule": "45 * * * *" },
    { "path": "/api/cron/booking-events-invariants", "schedule": "15 * * * *" }
  ]
}
