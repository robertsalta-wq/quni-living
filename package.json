{
  "name": "quni-living",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "node scripts/run-with-env.mjs npx vercel dev",
    "env:pull": "vercel env pull .env.vercel -y",
    "env:pull:production": "vercel env pull .env.vercel --environment production -y",
    "dev:refresh": "vite --force",
    "build": "tsc -b && vite build",
    "build:capacitor": "node scripts/build-capacitor.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build:capacitor && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android",
    "generate:android-icons": "node scripts/generate-android-launcher-icons.mjs",
    "seed:properties": "npx tsx src/scripts/seedProperties.ts",
    "generate:suburbs": "node scripts/suburb-generator/generate.js",
    "supabase:deploy:functions": "npx supabase@latest functions deploy send-uni-otp && npx supabase@latest functions deploy verify-uni-otp && npx supabase@latest functions deploy send-work-otp && npx supabase@latest functions deploy verify-work-otp && npx supabase@latest functions deploy delete-student-account --no-verify-jwt && npx supabase@latest functions deploy delete-user-documents --no-verify-jwt && npx supabase@latest functions deploy stripe-webhook --no-verify-jwt"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/push-notifications": "^8.0.3",
    "@marsidev/react-turnstile": "^1.4.2",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/react": "^10.45.0",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@supabase/supabase-js": "^2.99.3",
    "@types/react-router-dom": "^5.3.3",
    "@vercel/functions": "^3.4.3",
    "dotenv": "^17.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.4",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
