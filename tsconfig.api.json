{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.api.tsbuildinfo",
    "lib": ["ES2023", "DOM"],
    "types": ["node", "vite/client"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowImportingTsExtensions": false,
    "jsx": "react-jsx"
  },
  "include": [
    "api/**/*.ts",
    "api/**/*.tsx",
    "api/documents/NswOccupancyAgreement.js",
    "api/documents/QldOccupancyAgreement.js",
    "src/lib/database.types.ts",
    "src/lib/documents/OccupancyAgreement.tsx",
    "src/lib/documents/NswResidentialTenancyAgreement.tsx",
    "src/lib/documents/QuniPlatformAddendum.tsx",
    "src/lib/documents/QuniPlatformAddendumQld.tsx",
    "src/lib/documents/QuniOccupancyAgreementQld.tsx",
    "src/lib/documents/QldGeneralTenancyAgreement.tsx",
    "src/lib/documents/qld/form18aStandardTerms.ts",
    "src/lib/documents/qld/qldForm18aClauseRender.tsx",
    "src/lib/documents/ft6600EmbeddedStrings.ts",
    "src/lib/docuseal.ts"
  ]
}
