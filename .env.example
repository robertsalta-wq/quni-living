# Copy to .env.local and fill in from Supabase → Project Settings → API
# Never commit .env.local (ignored via *.local)

# SEO: canonical https origin, no trailing slash (update public/robots.txt + sitemap.xml if you use a custom domain)
# VITE_SITE_URL=https://quni-living.vercel.app
# Optional default Open Graph image (absolute URL, e.g. 1200×630 JPG)
# VITE_OG_IMAGE_URL=

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key only (sb_publishable_… or legacy anon JWT eyJ…). NEVER sb_secret_… or service_role.
VITE_SUPABASE_ANON_KEY=your_publishable_key_here

# EmailJS — listing enquiry (confirmation to sender + notify to hello@quni.com.au)
# Service ID = dashboard → Email Services (e.g. service_abc123), NOT the template id
# VITE_EMAILJS_SERVICE_ID=
# Public Key = Account → API keys (same EmailJS account as the service)
# VITE_EMAILJS_PUBLIC_KEY=
# Template IDs = Email Templates (e.g. template_xyz)
# VITE_EMAILJS_ENQUIRY_CONFIRMATION_TEMPLATE_ID=
# VITE_EMAILJS_ENQUIRY_NOTIFY_TEMPLATE_ID=
# Contact page (template vars: sender_name, sender_email, subject, message)
# VITE_EMAILJS_CONTACT_TEMPLATE_ID=
# Landlord partnerships lead (notify hello@quni.com.au — use notify_to / to_email; body: lead_name, lead_email, lead_phone, lead_suburb, property_count, lead_message, message)
# VITE_EMAILJS_LANDLORD_LEAD_TEMPLATE_ID=

# Cloudflare Turnstile (enquiry + booking forms) — https://dash.cloudflare.com/ → Turnstile
# VITE_TURNSTILE_SITE_KEY=
# Vercel only (secret): TURNSTILE_SECRET_KEY=
# Optional local dev: point verify to a deployed API
# VITE_TURNSTILE_VERIFY_URL=https://your-app.vercel.app/api/verify-turnstile

# Stripe (Payment Element / future checkout — publishable key only in Vite)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# --- Vercel → Project → Settings → Environment Variables (then Redeploy) ---
# Server-only; never use VITE_ prefix for these.
#   STRIPE_SECRET_KEY=sk_test_… or sk_live_…
#   STRIPE_WEBHOOK_SECRET=whsec_…
#   SUPABASE_URL=same URL as VITE_SUPABASE_URL (no VITE_ prefix)
#   SUPABASE_SERVICE_ROLE_KEY=service_role JWT from Supabase → API (secret). MUST NOT be the
#     same as anon/publishable — if you paste anon here, Stripe Connect saves 0 rows and
#     stripe_connect_account_id stays NULL with no obvious error.
#   SUPABASE_ANON_KEY=EXACT same value as VITE_SUPABASE_ANON_KEY (publishable/anon key)
#     Required for /api/create-connect-account-link to verify the user JWT.
#     If you only set VITE_SUPABASE_ANON_KEY in Vercel, the API uses that too (no duplicate needed).
#   RESEND_API_KEY=re_...  (booking notification emails — Resend dashboard → API Keys)
# Optional: SITE_URL or PUBLIC_SITE_URL=https://your-production-domain.com
# Serverless → serverless doc flow uses this or VERCEL_URL (set by Vercel) for absolute /api URLs:
# VERCEL_URL=https://quni-living.vercel.app
#
# Anthropic (AI listing descriptions — /api/ai/generate-description)
# ANTHROPIC_API_KEY=

# DocuSeal (self-hosted lease signing — sign.quni.com.au)
# DOCUSEAL_API_URL=https://sign.quni.com.au
# DOCUSEAL_API_TOKEN=
# Optional if your instance uses a different path than /api/submissions/pdf:
# DOCUSEAL_SUBMISSIONS_PATH=/api/submissions/pdf
#
# Internal trigger from booking confirmation → POST /api/documents/generate-lease
# INTERNAL_DOC_FLOW_SECRET= (generate a long random string; same value in Vercel)

# For local API routes: copy the Vercel names above into .env.local (still no VITE_ on
# secrets) and run: npx vercel dev
